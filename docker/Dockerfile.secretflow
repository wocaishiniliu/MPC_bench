FROM docker.io/library/python:3.10-slim

RUN pip install --no-cache-dir \
    pytest numpy pandas scikit-learn torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu \
    && pip install --no-cache-dir \
    jax jaxlib grpcio protobuf cloudpickle multiprocess psutil

WORKDIR /workspace
ENV PYTHONPATH=/workspace
ENV OMP_NUM_THREADS=1
